SOCIAL_DATA_MODE=api
APP_BASE_URL=http://localhost:3000
SOCIAL_AUTH_DEBUG=false
DATABASE_URL=

# Required in SOCIAL_DATA_MODE=api. Use at least 32 characters and keep it secret.
TOKEN_ENCRYPTION_KEY=

# Meta / Facebook / Instagram
META_GRAPH_API_VERSION=v22.0
META_CLIENT_ID=
META_CLIENT_SECRET=
META_REDIRECT_URI=http://localhost:3000/api/auth/social/meta/callback

# X / Twitter
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:3000/api/auth/social/x/callback

# YouTube / Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/social/youtube/callback
